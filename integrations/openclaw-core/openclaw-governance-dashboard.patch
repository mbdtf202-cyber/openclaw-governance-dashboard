index 000000000..0c3891e35
--- /dev/null
+++ b/ui/src/ui/controllers/governance.test.ts
@@ -0,0 +1,58 @@
+import { describe, expect, it, vi } from "vitest";
+import { hasGovernanceSupport, loadGovernance } from "./governance.ts";
+
+describe("hasGovernanceSupport", () => {
+  it("detects the governance snapshot method", () => {
+    expect(
+      hasGovernanceSupport({
+        hello: {
+          type: "hello-ok",
+          protocol: 3,
+          features: { methods: ["health", "governance.snapshot"] },
+        },
+      }),
+    ).toBe(true);
+    expect(
+      hasGovernanceSupport({
+        hello: {
+          type: "hello-ok",
+          protocol: 3,
+          features: { methods: ["health"] },
+        },
+      }),
+    ).toBe(false);
+  });
+});
+
+describe("loadGovernance", () => {
+  it("loads the governance snapshot when supported", async () => {
+    const request = vi.fn().mockResolvedValue({
+      available: true,
+      pluginId: "governance-dashboard",
+      refreshedAt: new Date(0).toISOString(),
+      config: {
+        refreshIntervalMs: 1000,
+        largeFileLineThreshold: 500,
+        hotspotLimit: 12,
+      },
+      snapshot: null,
+    });
+    const state = {
+      client: { request },
+      connected: true,
+      hello: {
+        type: "hello-ok" as const,
+        protocol: 3,
+        features: { methods: ["governance.snapshot"] },
+      },
+      governanceLoading: false,
+      governanceResult: null,
+      governanceError: null,
+    };
+
+    await loadGovernance(state, { force: true });
+
+    expect(request).toHaveBeenCalledWith("governance.snapshot", { force: true });
+    expect(state.governanceResult?.pluginId).toBe("governance-dashboard");
+  });
+});
