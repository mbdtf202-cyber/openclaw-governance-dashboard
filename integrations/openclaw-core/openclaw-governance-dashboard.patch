+import type { GatewayHelloOk, GatewayBrowserClient } from "../gateway.ts";
+import type { GovernanceSnapshotResult } from "../types.ts";
+
+export type GovernanceState = {
+  client: GatewayBrowserClient | null;
+  connected: boolean;
+  hello: GatewayHelloOk | null;
+  governanceLoading: boolean;
+  governanceResult: GovernanceSnapshotResult | null;
+  governanceError: string | null;
+};
+
+export function hasGovernanceSupport(state: Pick<GovernanceState, "hello">): boolean {
+  const methods = state.hello?.features?.methods;
+  return Array.isArray(methods) && methods.includes("governance.snapshot");
+}
+
+export async function loadGovernance(state: GovernanceState, options?: { force?: boolean }) {
+  if (!state.client || !state.connected) {
+    return;
+  }
+  if (!hasGovernanceSupport(state)) {
+    state.governanceResult = null;
+    state.governanceError = null;
+    return;
+  }
+  if (state.governanceLoading) {
+    return;
+  }
+  state.governanceLoading = true;
+  state.governanceError = null;
+  try {
+    const res = await state.client.request<GovernanceSnapshotResult>("governance.snapshot", {
+      force: options?.force === true,
+    });
+    state.governanceResult = res;
+  } catch (err) {
+    state.governanceError = String(err);
+  } finally {
+    state.governanceLoading = false;
+  }
+}
