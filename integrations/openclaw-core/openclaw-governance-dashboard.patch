index 000000000..2150e9f86
--- /dev/null
+++ b/ui/src/ui/views/governance.ts
@@ -0,0 +1,276 @@
+import { html, nothing } from "lit";
+import { formatRelativeTimestamp } from "../format.ts";
+import type {
+  GovernanceArtifact,
+  GovernanceDomain,
+  GovernanceGuardrail,
+  GovernanceHotspot,
+  GovernanceIssue,
+  GovernanceSnapshotResult,
+} from "../types.ts";
+
+export type GovernanceProps = {
+  loading: boolean;
+  error: string | null;
+  supported: boolean;
+  result: GovernanceSnapshotResult | null;
+  onRefresh: (force?: boolean) => void;
+};
+
+function toneClass(status: "ok" | "warn" | "missing" | "high" | "medium" | "low") {
+  if (status === "ok" || status === "low") {
+    return "ok";
+  }
+  if (status === "warn" || status === "medium") {
+    return "warn";
+  }
+  return "danger";
+}
+
+function renderInstallState(props: GovernanceProps) {
+  return html`
+    <section class="card">
+      <div class="card-title">Governance plugin not loaded</div>
+      <div class="card-sub">
+        Install the optional governance extension to surface repo boundaries, ownership signals, and
+        architecture guardrails inside Control UI.
+      </div>
+      <div class="governance-actions">
+        <button class="btn" @click=${() => props.onRefresh(false)}>Retry detection</button>
+      </div>
+      <div class="governance-codeblock">
+        <div><strong>Local checkout</strong></div>
+        <code>openclaw plugins install ./extensions/governance-dashboard</code>
+      </div>
+      <div class="governance-codeblock">
+        <div><strong>GitHub release asset</strong></div>
+        <code>openclaw plugins install ./openclaw-governance-dashboard.tgz</code>
+      </div>
+    </section>
+  `;
+}
+
+function renderGuardrail(guardrail: GovernanceGuardrail) {
+  return html`
+    <div class="governance-panel">
+      <div class="governance-panel__top">
+        <div class="governance-panel__title">${guardrail.label}</div>
+        <span class="pill ${toneClass(guardrail.status)}">${guardrail.status}</span>
+      </div>
+      <div class="governance-panel__body">${guardrail.detail}</div>
+    </div>
+  `;
+}
+
+function renderIssue(issue: GovernanceIssue) {
+  return html`
+    <div class="governance-issue">
+      <div class="governance-panel__top">
+        <div class="governance-panel__title">${issue.title}</div>
+        <span class="pill ${toneClass(issue.severity)}">${issue.severity}</span>
+      </div>
+      <div class="governance-panel__body">${issue.detail}</div>
+      ${issue.path ? html`<div class="governance-meta mono">${issue.path}</div>` : nothing}
+      ${issue.action ? html`<div class="governance-meta">${issue.action}</div>` : nothing}
+    </div>
+  `;
+}
+
+function renderHotspot(hotspot: GovernanceHotspot) {
+  return html`
+    <div class="governance-list__row">
+      <div>
+        <div class="governance-list__title mono">${hotspot.path}</div>
+        ${hotspot.category ? html`<div class="governance-meta">${hotspot.category}</div>` : nothing}
+      </div>
+      <div class="governance-list__metric">${hotspot.lines} lines</div>
+    </div>
+  `;
+}
+
+function renderDomain(domain: GovernanceDomain) {
+  return html`
+    <div class="governance-panel">
+      <div class="governance-panel__top">
+        <div class="governance-panel__title">${domain.label}</div>
+        ${domain.maturity ? html`<span class="pill">${domain.maturity}</span>` : nothing}
+      </div>
+      ${domain.description ? html`<div class="governance-panel__body">${domain.description}</div>` : nothing}
+      <div class="governance-meta">
+        ${domain.fileCount ?? 0} files
+        ${typeof domain.largeFileCount === "number" ? ` · ${domain.largeFileCount} large files` : ""}
+        ${typeof domain.issueCount === "number" ? ` · ${domain.issueCount} issues` : ""}
+      </div>
+      ${
+        Array.isArray(domain.paths) && domain.paths.length > 0
+          ? html`<div class="governance-tagrow">
+              ${domain.paths.map((entry) => html`<span class="governance-tag mono">${entry}</span>`)}
+            </div>`
+          : nothing
+      }
+      ${
+        Array.isArray(domain.owners) && domain.owners.length > 0
+          ? html`<div class="governance-meta">Owners: ${domain.owners.join(", ")}</div>`
+          : html`
+              <div class="governance-meta">Owners: unassigned</div>
+            `
+      }
+    </div>
+  `;
+}
+
+function renderArtifact(artifact: GovernanceArtifact) {
+  return html`
+    <div class="governance-list__row">
+      <div>
+        <div class="governance-list__title">${artifact.label}</div>
+        <div class="governance-meta mono">${artifact.path}</div>
+      </div>
+      <div class="governance-list__metric">${artifact.kind}</div>
+    </div>
+  `;
+}
+
+export function renderGovernance(props: GovernanceProps) {
+  if (!props.supported) {
+    return renderInstallState(props);
+  }
+
+  const result = props.result;
+  const snapshot = result?.snapshot ?? null;
+  const cards = snapshot?.cards ?? [];
+  const guardrails = snapshot?.guardrails ?? [];
+  const issues = snapshot?.issues ?? [];
+  const hotspots = snapshot?.hotspots ?? [];
+  const domains = snapshot?.domains ?? [];
+  const artifacts = snapshot?.artifacts ?? [];
+  const refreshedAtMs = result ? Date.parse(result.refreshedAt) : Number.NaN;
+
+  return html`
+    <section class="card">
+      <div class="governance-header">
+        <div>
+          <div class="card-title">Governance cockpit</div>
+          <div class="card-sub">
+            ${result?.repoRoot ?? snapshot?.repoRoot ?? "Repo root unresolved"}
+          </div>
+        </div>
+        <div class="governance-actions">
+          <button class="btn" ?disabled=${props.loading} @click=${() => props.onRefresh(false)}>
+            ${props.loading ? "Loading..." : "Refresh cache"}
+          </button>
+          <button class="btn primary" ?disabled=${props.loading} @click=${() => props.onRefresh(true)}>
+            ${props.loading ? "Scanning..." : "Rescan repo"}
+          </button>
+        </div>
+      </div>
+
+      ${
+        props.error
+          ? html`<div class="callout danger"><strong>Load failed.</strong> ${props.error}</div>`
+          : nothing
+      }
+      ${result?.message ? html`<div class="callout warn">${result.message}</div>` : nothing}
+
+      ${
+        result
+          ? html`<div class="governance-meta">
+              plugin ${result.pluginId}${result.pluginVersion ? ` v${result.pluginVersion}` : ""}
+              · refreshed ${Number.isFinite(refreshedAtMs) ? formatRelativeTimestamp(refreshedAtMs) : result.refreshedAt}
+              · threshold ${result.config.largeFileLineThreshold} lines
+            </div>`
+          : nothing
+      }
+    </section>
+
+    ${
+      snapshot
+        ? html`
+            <section class="governance-cards">
+              ${cards.map(
+                (card) => html`
+                  <article class="governance-stat governance-stat--${card.tone ?? "neutral"}">
+                    <div class="governance-stat__label">${card.label}</div>
+                    <div class="governance-stat__value">${card.value}</div>
+                    ${card.helper ? html`<div class="governance-meta">${card.helper}</div>` : nothing}
+                  </article>
+                `,
+              )}
+            </section>
+
+            <section class="governance-grid">
+              <article class="card">
+                <div class="card-title">Guardrails</div>
+                <div class="card-sub">Repository-level checks that define structural hygiene.</div>
+                <div class="governance-stack">
+                  ${guardrails.map((entry) => renderGuardrail(entry))}
+                </div>
+              </article>
+
+              <article class="card">
+                <div class="card-title">Priority issues</div>
+                <div class="card-sub">What currently weakens the governance baseline.</div>
+                ${
+                  issues.length > 0
+                    ? html`<div class="governance-stack">${issues.map((entry) => renderIssue(entry))}</div>`
+                    : html`
+                        <div class="governance-empty">No active governance issues in the latest scan.</div>
+                      `
+                }
+              </article>
+            </section>
+
+            <section class="governance-grid">
+              <article class="card">
+                <div class="card-title">Large-file hotspots</div>
+                <div class="card-sub">Files that are most likely to accumulate coupling.</div>
+                ${
+                  hotspots.length > 0
+                    ? html`<div class="governance-list">${hotspots.map((entry) => renderHotspot(entry))}</div>`
+                    : html`
+                        <div class="governance-empty">No hotspots above the configured threshold.</div>
+                      `
+                }
+              </article>
+
+              <article class="card">
+                <div class="card-title">Governance artifacts</div>
+                <div class="card-sub">Skeleton files detected in the repository.</div>
+                ${
+                  artifacts.length > 0
+                    ? html`<div class="governance-list">${artifacts.map((entry) => renderArtifact(entry))}</div>`
+                    : html`
+                        <div class="governance-empty">No governance artifacts detected yet.</div>
+                      `
+                }
+              </article>
+            </section>
+
+            <section class="card">
+              <div class="card-title">Domain map</div>
+              <div class="card-sub">
+                Bounded contexts that keep growth inside explicit ownership seams.
+              </div>
+              ${
+                domains.length > 0
+                  ? html`<div class="governance-grid">${domains.map((entry) => renderDomain(entry))}</div>`
+                  : html`
+                      <div class="governance-empty">No domain map found. Add governance/domain-map.json.</div>
+                    `
+              }
+            </section>
+          `
+        : html`
+            <section class="card">
+              <div class="governance-empty">
+                ${
+                  props.loading
+                    ? "Governance snapshot is loading."
+                    : "No governance snapshot available yet. Run a repo rescan to seed the dashboard."
+                }
+              </div>
+            </section>
+          `
+    }
+  `;
+}
